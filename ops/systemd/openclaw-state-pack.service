[Unit]
Description=OpenClaw State Pack generator
After=ai-ops-runner.service openclaw-frontdoor.service
Wants=ai-ops-runner.service

[Service]
Type=oneshot
WorkingDirectory=/opt/ai-ops-runner
EnvironmentFile=-/etc/ai-ops-runner/openclaw.env
Environment=OPENCLAW_REPO_ROOT=/opt/ai-ops-runner
ExecStart=/bin/bash /opt/ai-ops-runner/ops/scripts/state_pack_generate.sh
SuccessExitStatus=10
TimeoutStartSec=300
